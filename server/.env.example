PORT=3001

# ==========================================
# FACEBOOK CONFIGURATION
# ==========================================
# Get your access token from: https://developers.facebook.com/tools/explorer/
# Required permissions: pages_manage_posts, pages_read_engagement, pages_show_list
FACEBOOK_ACCESS_TOKEN=

# Required for Token Auto-Refresh Feature
# Get these from: https://developers.facebook.com/apps/
# 1. Create or select your Facebook App
# 2. Go to Settings > Basic
# 3. Copy App ID and App Secret
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ==========================================
# SHOPEE CONFIGURATION
# ==========================================
# Get these from Shopee Open Platform: https://open.shopee.com/
# 1. Register as Shopee Partner
# 2. Create an App
# 3. Get Partner ID and Partner Key from App Settings
# 4. Get Shop ID from your shop settings

SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=

# Optional: Access Token (if using OAuth)
SHOPEE_ACCESS_TOKEN=

# ==========================================
# FUTURE PLATFORMS (Add as needed)
# ==========================================

# TikTok
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_ACCESS_TOKEN=

# YouTube
# YOUTUBE_API_KEY=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=

# Instagram
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Lazada
# LAZADA_APP_KEY=
# LAZADA_APP_SECRET=
# LAZADA_ACCESS_TOKEN=
