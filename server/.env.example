PORT=5000

# Facebook Configuration
# Get your access token from: https://developers.facebook.com/tools/explorer/
# Required permissions: pages_manage_posts, pages_read_engagement, pages_show_list
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

# Add your fanpage IDs (comma separated)
# You can find page ID in Page Settings -> About
FANPAGE_IDS=page_id_1,page_id_2,page_id_3
